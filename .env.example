OHEY_ENV=local
PORT=8080
SUPABASE_URL=https://wwyaftonswgxnjcceyfb.supabase.co
SUPABASE_ANON_KEY=replace_with_dev_ohey_publishable_key
# Required only for /v1/admin/* endpoints. Never expose this in Flutter.
SUPABASE_SERVICE_ROLE_KEY=
# Auth provider is switchable during the Clerk migration. Use supabase until
# Mobile sends Clerk session tokens and data access no longer depends on
# Supabase RLS with Supabase JWTs.
AUTH_PROVIDER=supabase
# Required when AUTH_PROVIDER=clerk. Example: https://your-app.clerk.accounts.dev
CLERK_ISSUER=
# Optional; defaults to ${CLERK_ISSUER}/.well-known/jwks.json
CLERK_JWKS_URL=
# Optional audience check for Clerk session tokens.
CLERK_AUDIENCE=
ALLOWED_ORIGINS=*
# Optional: Firebase service account JSON (or base64 JSON) for FCM push delivery.
FCM_SERVICE_ACCOUNT_JSON=
