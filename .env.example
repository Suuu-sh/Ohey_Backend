APP_ENV=local
PORT=8080
DATA_STORE=neon
# Required. Prefer Neon pooled app URLs (*-pooler* host) for the API runtime;
# use direct URLs for migrations/dumps.
DATABASE_URL=
DATABASE_MAX_CONNS=10
AUTH_PROVIDER=clerk
# Required. Example: https://your-app.clerk.accounts.dev
CLERK_ISSUER=
# Optional; defaults to ${CLERK_ISSUER}/.well-known/jwks.json
CLERK_JWKS_URL=
# Optional audience check for Clerk session tokens.
CLERK_AUDIENCE=
# Required for Clerk user create/delete admin flows.
CLERK_SECRET_KEY=
# Comma-separated browser origins allowed to call the API. Native apps do not
# need CORS; keep production restricted to owned HTTPS origins.
ALLOWED_ORIGINS=http://localhost:3000
# Optional: Firebase service account JSON (or base64 JSON) for FCM push delivery.
FCM_SERVICE_ACCOUNT_JSON=

# Optional shared-api-proxy origin guard. Set the same secret on the Cloudflare
# Worker as ORIGIN_VERIFY_SECRET; when set here, direct origin requests without
# X-Origin-Verify are rejected except health checks.
ORIGIN_VERIFY_SECRET=

# Clerk custom email delivery via Resend. Subscribe /webhooks/clerk/email to Clerk email.created events.
CLERK_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Ohey <noreply@your-domain.com>
RESEND_REPLY_TO_EMAIL=

# Cloudflare R2 storage. R2_PUBLIC_URL should be a public bucket/custom-domain base URL.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ohey-public
R2_PUBLIC_URL=
