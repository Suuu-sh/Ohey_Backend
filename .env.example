OHEY_ENV=local
PORT=8080
# Supabase variables are no longer required for Clerk + Neon runtime.
# Keep only in temporary rollback environments.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATA_STORE=neon
# Required when DATA_STORE=neon or DATA_STORE=postgres. Prefer Neon pooled app URLs
# (*-pooler* host) for the API runtime; use direct URLs for migrations/dumps.
DATABASE_URL=
DATABASE_MAX_CONNS=10
AUTH_PROVIDER=clerk
# Required when AUTH_PROVIDER=clerk. Example: https://your-app.clerk.accounts.dev
CLERK_ISSUER=
# Optional; defaults to ${CLERK_ISSUER}/.well-known/jwks.json
CLERK_JWKS_URL=
# Optional audience check for Clerk session tokens.
CLERK_AUDIENCE=
# Required for Clerk user create/delete admin flows.
CLERK_SECRET_KEY=
ALLOWED_ORIGINS=*
# Optional: Firebase service account JSON (or base64 JSON) for FCM push delivery.
FCM_SERVICE_ACCOUNT_JSON=
